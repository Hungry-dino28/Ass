    <div id="productModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>

        <img id="modalImg" src="" style="width:100px;"><br><br>
        <h2 id="modalName"></h2>
        <h3 id="modalPrice"></h3>

        <button>Confirm Buy</button>
    </div>
</div>


